<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".ui.GameActivity">

    <!-- 1. Game Info Panel (Score, Moves, Time) -->
    <LinearLayout
        android:id="@+id/game_info_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_surface_color"
        android:elevation="2dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Score -->
        <TextView
            android:id="@+id/tv_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="viewStart"
            android:textColor="@color/secondary_text_color"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Score: 120" />

        <!-- Moves -->
        <TextView
            android:id="@+id/tv_moves"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="center"
            android:textColor="@color/secondary_text_color"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Moves: 15" />

        <!-- Time -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="center"
            android:textColor="@color/secondary_text_color"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Time: 0:35" />

        <!-- Gems total -->
        <LinearLayout
            android:id="@+id/gems_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_gem_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_gem_count_oval"
                android:minWidth="26dp"
                android:paddingStart="6dp"
                android:paddingTop="1dp"
                android:paddingEnd="6dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="0" />

            <ImageView
                android:id="@+id/iv_gem_bag"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/gems_total_label"
                android:scaleType="fitCenter"
                android:src="@drawable/gems_empty_bag_1536x1536" />
        </LinearLayout>

        <!-- Helps-ticket total -->
        <LinearLayout
            android:id="@+id/tickets_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_ticket_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_gem_count_oval"
                android:minWidth="26dp"
                android:paddingStart="6dp"
                android:paddingTop="1dp"
                android:paddingEnd="6dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="0" />

            <ImageView
                android:id="@+id/iv_ticket_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/tickets_total_label"
                android:scaleType="fitCenter"
                android:src="@drawable/ticket_yellow_on_green_768x384" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2. Main Content Area: Game Board on Left, Controls on Right -->
    <com.gpgamelab.justpatience.ui.GameBoardView
        android:id="@+id/game_board_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/adView"
        app:layout_constraintEnd_toStartOf="@id/control_buttons_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/game_info_panel" />

    <Button
        android:id="@+id/btn_daily_bonus_test"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:text="@string/daily_bonus_test_button"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="@id/game_board_view"
        app:layout_constraintStart_toStartOf="@id/game_board_view"
        app:strokeColor="@color/secondary_button_color" />

    <!-- 3. Control Buttons Panel (Right Side) -->
    <LinearLayout
        android:id="@+id/control_buttons_layout"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toTopOf="@id/adView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/game_info_panel">

        <Button
            android:id="@+id/btn_new_game"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/new_game_button_text"
            android:layout_marginBottom="6dp"
            android:textColor="@color/colorPrimary"
            app:strokeColor="@color/colorPrimary" />

        <FrameLayout
            android:id="@+id/move_controls_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_control_group_outline"
            android:paddingStart="4dp"
            android:paddingTop="4dp"
            android:paddingEnd="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="4dp">

                    <FrameLayout
                        android:id="@+id/btnUndo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="4dp"
                        android:background="?android:attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/undo_main"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/undo_gray"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/action_undo" />

                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btnRedo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?android:attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/redo_main"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/redo_gray"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/action_redo" />

                    </FrameLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_hint"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/action_hint"
                    android:textColor="@color/secondary_button_color"
                    app:strokeColor="@color/secondary_button_color" />

                <Button
                    android:id="@+id/btn_restart"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/restart_game_text"
                    android:layout_marginBottom="4dp"
                    android:textColor="@color/secondary_button_color"
                    app:strokeColor="@color/secondary_button_color" />

                <Button
                    android:id="@+id/btn_auto_move"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_move_button_text"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/secondary_button_color"
                    app:strokeColor="@color/secondary_button_color" />

            </LinearLayout>

            <ImageView
                android:id="@+id/group_ad_overlay"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="top|start"
                android:layout_margin="1dp"
                android:src="@drawable/ic_play_ad_01" />

        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stats"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:contentDescription="Menu"
            android:text="MENU"
            android:textAllCaps="false"
            android:layout_marginBottom="6dp"
            android:translationY="-4px"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_menu_green_512x512"
            app:iconGravity="textTop"
            app:iconPadding="-12px"
            app:iconSize="48dp"
            app:iconTint="@null"
            app:strokeColor="@color/secondary_button_color" />

    </LinearLayout>

    <!-- 4. Banner Ad (at the very bottom, below game board and controls) -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:adSize="BANNER"
        app:adUnitId="@string/banner_ad_unit_id"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/fakeBannerView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_surface_color"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/fake_ad_message"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>

