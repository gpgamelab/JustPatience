<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_help_unlock_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        android:text="UNDO" />

    <TextView
        android:id="@+id/tv_help_unlock_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:lineSpacingExtra="2dp"
        android:layout_marginBottom="16dp"
        android:text="You have no more Help Coupons." />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_unlock_with_gems"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_horizontal_lt_green_512x256"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:text="3 gems" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btn_unlock_with_ad"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:background="@drawable/button_horizontal_lt_green_512x256"
            android:padding="10dp"
            android:contentDescription="@string/help_unlock_watch_ad"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play_ad_01" />
    </LinearLayout>

</LinearLayout>

