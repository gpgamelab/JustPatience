<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="160dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/iv_unlock_popup_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/ic_popup_rect_blue"
        android:scaleType="fitXY" />

    <LinearLayout
        android:id="@+id/layout_unlock_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_help_unlock_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="16dp"
            android:text="@string/help_unlock_ad_only_description_default" />

        <LinearLayout
            android:id="@+id/layout_unlock_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_unlock_with_ad"
                android:layout_width="50dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/ic_button_orange_orange_ad_unlock"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/help_unlock_watch_ad" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_unlock_cancel"
                android:layout_width="50dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:background="@drawable/ic_button_orange_orange_cancel"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/cancel" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
