<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".ui.GameActivity">

    <!-- 1. Game Info Panel (Score, Moves, Time) -->
    <LinearLayout
        android:id="@+id/game_info_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_surface_color"
        android:elevation="2dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Score -->
        <TextView
            android:id="@+id/tv_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="viewStart"
            android:textColor="@color/secondary_text_color"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Score: 120" />

        <!-- Moves -->
        <TextView
            android:id="@+id/tv_moves"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="center"
            android:textColor="@color/secondary_text_color"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Moves: 15" />

        <!-- Time -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="center"
            android:textColor="@color/secondary_text_color"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Time: 0:35" />

        <!-- Gems total -->
        <LinearLayout
            android:id="@+id/gems_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_gem_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_gem_count_oval"
                android:minWidth="28dp"
                android:paddingStart="6dp"
                android:paddingTop="1dp"
                android:paddingEnd="6dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="0" />

            <ImageView
                android:id="@+id/iv_gem_bag"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/gems_total_label"
                android:scaleType="fitCenter"
                android:src="@drawable/gems_empty_bag_1536x1536" />
        </LinearLayout>

        <!-- Helps-ticket total -->
        <LinearLayout
            android:id="@+id/tickets_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_ticket_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_gem_count_oval"
                android:minWidth="28dp"
                android:paddingStart="6dp"
                android:paddingTop="1dp"
                android:paddingEnd="6dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="0" />

            <ImageView
                android:id="@+id/iv_ticket_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/tickets_total_label"
                android:scaleType="fitCenter"
                android:src="@drawable/ticket_yellow_on_green_768x384" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2. Custom Game Board View -->
    <!-- This is where the GameActivity.GameBoardView class will handle all card drawing and touch logic. -->
    <com.gpgamelab.justpatience.ui.GameBoardView
        android:id="@+id/game_board_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/control_buttons_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/game_info_panel" />


    <LinearLayout
        android:id="@+id/control_buttons_layout"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/adView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_new_game"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="50dp"
            android:layout_height="80dp"
            android:layout_marginEnd="2dp"
            android:text="@string/new_game_button_text"
            android:textColor="@color/colorPrimary"
            app:strokeColor="@color/colorPrimary" />

        <!-- Button
            android:id="@+id/btn_undo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/undo_button_text"
            android:layout_marginEnd="8dp"
            android:textColor="@color/secondary_button_color"
            app:strokeColor="@color/secondary_button_color" / -->

<!--        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/Undo_Red"
            android:background="@null" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/Redo_Blue"
            android:background="@null" />-->

        <FrameLayout
            android:id="@+id/move_controls_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:paddingStart="3dp"
            android:paddingTop="2dp"
            android:paddingEnd="3dp"
            android:paddingBottom="2dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/btnUndo"
            android:layout_width="30dp"
            android:layout_height="72dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/undo_main"
                android:layout_width="30dp"
                android:layout_height="66dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/action_undo"
                android:scaleType="fitCenter"
                android:src="@drawable/undo_gray" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnRedo"
            android:layout_width="30dp"
            android:layout_height="72dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/redo_main"
                android:layout_width="30dp"
                android:layout_height="66dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/action_redo"
                android:scaleType="fitCenter"
                android:src="@drawable/redo_gray" />

        </FrameLayout>

        <Button
            android:id="@+id/btn_hint"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="50dp"
            android:layout_height="72dp"
            android:layout_marginEnd="1dp"
            android:text="@string/action_hint"
            android:textColor="@color/secondary_button_color"
            app:strokeColor="@color/secondary_button_color" />

        <FrameLayout
            android:id="@+id/btnRestart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="1dp">

            <Button
                android:id="@+id/btn_restart"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="62dp"
                android:layout_height="72dp"
                android:text="@string/restart_game_text"
                android:textColor="@color/secondary_button_color"
                app:strokeColor="@color/secondary_button_color" />

        </FrameLayout>

        <Button
            android:id="@+id/btn_auto_move"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="52dp"
            android:layout_height="72dp"
            android:layout_marginEnd="0dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/auto_move_button_text"
            android:textColor="@color/secondary_button_color"
            app:strokeColor="@color/secondary_button_color" />

        </LinearLayout>


        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stats"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="56dp"
            android:layout_height="80dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Menu"
            android:text="MENU"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_menu_green_512x512"
            app:iconGravity="textTop"
            app:iconPadding="-4px"
            app:iconSize="48dp"
            app:iconTint="@null"
            app:strokeColor="@color/secondary_button_color" />

    </LinearLayout>

    <!-- Testers-only button: lower-left corner of the game board area.
         This button will eventually be removed from production builds,
         but the backing logic in GameActivity remains permanently. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_testers"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        android:alpha="0.65"
        android:text="@string/board_button_testers"
        android:textSize="9sp"
        android:textColor="#AAAAAA"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        app:strokeColor="#555555"
        app:layout_constraintBottom_toTopOf="@id/control_buttons_layout"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_develop"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:alpha="0.65"
        android:text="@string/board_button_develop"
        android:textSize="9sp"
        android:textColor="#90CAF9"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        app:strokeColor="#4F83CC"
        app:layout_constraintBottom_toBottomOf="@id/btn_testers"
        app:layout_constraintStart_toEndOf="@id/btn_testers"
        app:layout_constraintTop_toTopOf="@id/btn_testers" />

    <!-- 3. Banner Ad (at the very bottom, below buttons, full width) -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:adSize="BANNER"
        app:adUnitId="@string/banner_ad_unit_id"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/fakeBannerView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_surface_color"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/fake_ad_message"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>