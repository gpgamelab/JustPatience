<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".ui.GameActivity">

    <!-- 1. Game Info Panel (Score, Moves, Time) -->
    <LinearLayout
        android:id="@+id/game_info_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_surface_color"
        android:elevation="2dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Score -->
        <TextView
            android:id="@+id/tv_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="viewStart"
            android:textColor="@color/secondary_text_color"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Score: 120" />

        <!-- Moves -->
        <TextView
            android:id="@+id/tv_moves"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="center"
            android:textColor="@color/secondary_text_color"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Moves: 15" />

        <!-- Time -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="center"
            android:textColor="@color/secondary_text_color"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Time: 0:35" />

        <!-- Gems total -->
        <LinearLayout
            android:id="@+id/gems_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_gem_bag"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/gems_total_label"
                android:scaleType="fitCenter"
                android:src="@drawable/gems_empty_bag_1536x1536" />

            <TextView
                android:id="@+id/tv_gem_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_gem_count_oval"
                android:minWidth="28dp"
                android:paddingStart="6dp"
                android:paddingTop="1dp"
                android:paddingEnd="6dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="0" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2. Custom Game Board View -->
    <!-- This is where the GameActivity.GameBoardView class will handle all card drawing and touch logic. -->
    <com.gpgamelab.justpatience.ui.GameBoardView
        android:id="@+id/game_board_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/control_buttons_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/game_info_panel" />

    <LinearLayout
        android:id="@+id/control_buttons_layout"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/adView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_new_game"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="50dp"
            android:layout_height="80dp"
            android:layout_marginEnd="2dp"
            android:text="@string/new_game_button_text"
            android:textColor="@color/colorPrimary"
            app:strokeColor="@color/colorPrimary" />

        <!-- Button
            android:id="@+id/btn_undo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/undo_button_text"
            android:layout_marginEnd="8dp"
            android:textColor="@color/secondary_button_color"
            app:strokeColor="@color/secondary_button_color" / -->

<!--        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/Undo_Red"
            android:background="@null" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/Redo_Blue"
            android:background="@null" />-->

        <FrameLayout
            android:id="@+id/btnUndo"
            android:layout_width="32dp"
            android:layout_height="80dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/undo_main"
                android:layout_width="32dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/action_undo"
                android:scaleType="fitCenter"
                android:src="@drawable/undo_gray" />

            <ImageView
                android:id="@+id/undo_overlay"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|start"
                android:layout_marginTop="2dp"
                android:layout_margin="2dp"
                android:src="@drawable/ic_play_ad_01" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnRedo"
            android:layout_width="32dp"
            android:layout_height="80dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/redo_main"
                android:layout_width="32dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/action_redo"
                android:scaleType="fitCenter"
                android:src="@drawable/redo_gray" />

            <ImageView
                android:id="@+id/redo_overlay"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|start"
                android:layout_marginTop="4dp"
                android:layout_margin="2dp"
                android:src="@drawable/ic_play_ad_01" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnRestart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp">

            <Button
                android:id="@+id/btn_restart"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="70dp"
                android:layout_height="80dp"
                android:text="@string/restart_game_text"
                android:textColor="@color/secondary_button_color"
                app:strokeColor="@color/secondary_button_color" />

            <ImageView
                android:id="@+id/restart_overlay"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|start"
                android:layout_margin="2dp"
                android:src="@drawable/ic_play_ad_01" />

        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stats"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="56dp"
            android:layout_height="80dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Menu"
            android:text="MENU"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_menu_green_512x512"
            app:iconGravity="textTop"
            app:iconPadding="-4px"
            app:iconSize="48dp"
            app:iconTint="@null"
            app:strokeColor="@color/secondary_button_color" />

        <Button
            android:id="@+id/btn_auto_move"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="50dp"
            android:layout_height="80dp"
            android:layout_marginEnd="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/auto_move_button_text"
            android:textColor="@color/secondary_button_color"
            app:strokeColor="@color/secondary_button_color" />

    </LinearLayout>

    <!-- 3. Banner Ad (at the very bottom, below buttons, full width) -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:adSize="BANNER"
        app:adUnitId="@string/banner_ad_unit_id"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Win celebration video overlay (hidden until a hand is won). -->
    <FrameLayout
        android:id="@+id/win_video_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <VideoView
            android:id="@+id/win_video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>