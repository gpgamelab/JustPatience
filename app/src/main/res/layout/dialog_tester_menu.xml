<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dark_surface_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tester_menu_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginBottom="16dp" />

        <!-- Section: Premium Account -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tester_menu_premium_section"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_tester_premium_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tester_menu_premium_disabled"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tester_premium_toggle"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tester_menu_enable"
                android:textColor="#00E676"
                app:strokeColor="#00E676" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginBottom="16dp" />

        <!-- Section: Gems -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tester_menu_gems_section"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gems_minus5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-5"
                android:textColor="#FF6B6B"
                app:strokeColor="#FF6B6B"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gems_minus1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-1"
                android:textColor="#FF6B6B"
                app:strokeColor="#FF6B6B"
                android:layout_marginStart="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gems_value"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                app:strokeColor="#777777"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gems_plus1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+1"
                android:textColor="#69F0AE"
                app:strokeColor="#69F0AE"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gems_plus5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+5"
                android:textColor="#69F0AE"
                app:strokeColor="#69F0AE"
                android:layout_marginStart="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginBottom="16dp" />

        <!-- Section: Coupons (Help Tickets) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tester_menu_coupons_section"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_coupons_minus5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-5"
                android:textColor="#FF6B6B"
                app:strokeColor="#FF6B6B"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_coupons_minus1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-1"
                android:textColor="#FF6B6B"
                app:strokeColor="#FF6B6B"
                android:layout_marginStart="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_coupons_value"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                app:strokeColor="#777777"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_coupons_plus1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+1"
                android:textColor="#69F0AE"
                app:strokeColor="#69F0AE"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_coupons_plus5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+5"
                android:textColor="#69F0AE"
                app:strokeColor="#69F0AE"
                android:layout_marginStart="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginBottom="16dp" />

        <!-- Section: Magic Wands -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tester_menu_magic_wands_section"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_magic_wands_minus5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-5"
                android:textColor="#FF6B6B"
                app:strokeColor="#FF6B6B"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_magic_wands_minus1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-1"
                android:textColor="#FF6B6B"
                app:strokeColor="#FF6B6B"
                android:layout_marginStart="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_magic_wands_value"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                app:strokeColor="#777777"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_magic_wands_plus1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+1"
                android:textColor="#69F0AE"
                app:strokeColor="#69F0AE"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_magic_wands_plus5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+5"
                android:textColor="#69F0AE"
                app:strokeColor="#69F0AE"
                android:layout_marginStart="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

        </LinearLayout>

         <!-- Trigger Win Sequence -->
         <View
             android:layout_width="match_parent"
             android:layout_height="1dp"
             android:background="#555555"
             android:layout_marginBottom="12dp" />

         <com.google.android.material.button.MaterialButton
             android:id="@+id/btn_tester_trigger_win"
             style="@style/Widget.MaterialComponents.Button.OutlinedButton"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="@string/tester_menu_trigger_win"
             android:textColor="#FFD740"
             android:textStyle="bold"
             app:strokeColor="#FFD740"
             android:layout_marginBottom="8dp" />

         <!-- Trigger Daily Bonus -->
         <com.google.android.material.button.MaterialButton
             android:id="@+id/btn_tester_trigger_daily_bonus"
             style="@style/Widget.MaterialComponents.Button.OutlinedButton"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="@string/tester_menu_trigger_daily_bonus"
             android:textColor="#FFD740"
             android:textStyle="bold"
             app:strokeColor="#FFD740"
             android:layout_marginBottom="8dp" />

         <!-- Trigger No Tickets Popup -->
         <com.google.android.material.button.MaterialButton
             android:id="@+id/btn_tester_trigger_no_tickets"
             style="@style/Widget.MaterialComponents.Button.OutlinedButton"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="@string/tester_menu_trigger_no_tickets"
             android:textColor="#FFD740"
             android:textStyle="bold"
             app:strokeColor="#FFD740"
             android:layout_marginBottom="8dp" />

        <!-- Extra space before the dangerous Reset button -->
        <View
            android:layout_width="match_parent"
            android:layout_height="36dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#7A2020"
            android:layout_marginBottom="12dp" />

        <!-- Reset Everything Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tester_reset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tester_menu_reset_everything"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#B00020"
            android:layout_marginBottom="20dp" />

        <!-- AdMob Device ID -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tester_admob_device_id"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AdMob Device ID"
            android:textColor="#40C4FF"
            app:strokeColor="#40C4FF"
            android:layout_marginBottom="8dp" />

        <!-- Close Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tester_close"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tester_menu_close"
            android:textColor="#CCCCCC"
            app:strokeColor="#666666" />

    </LinearLayout>
</ScrollView>

